# ========================================================================
# .gitignore - 遁甲归一项目 Git 忽略规则
# ========================================================================
# 
# 说明：此文件定义了 Git 版本控制中应该忽略的文件和目录
# 目的：防止敏感信息、临时文件和构建产物被提交到仓库
# 
# ========================================================================

# ====================================================================
# 【操作系统文件】
# 说明：各操作系统自动生成的隐藏文件和元数据
# ====================================================================

# macOS
.DS_Store
.AppleDouble
.LSOverride
._*

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# Linux
*~
.directory

# ====================================================================
# 【编辑器/IDE 配置】
# 说明：各编辑器生成的配置文件和临时文件
# ====================================================================

# VS Code
.vscode/
*.code-workspace

# Trae IDE
.trae/

# Sublime Text
*.sublime-project
*.sublime-workspace

# Vim
*.swp
*.swo
*~

# Emacs
*~
\#*\#
/.emacs.desktop
/.emacs.desktop.lock

# ====================================================================
# 【日志文件】
# 说明：运行时生成的日志文件
# ====================================================================

# 项目日志
*.log
-*.log

# 浏览器控制台导出的日志
*.log.*

# ====================================================================
# 【临时文件】
# 说明：开发过程中产生的临时文件
# ====================================================================

# 临时文件
*.tmp
*.temp
*.bak
*.swp

# 缓存目录
.cache/
tmp/
temp/

# ====================================================================
# 【构建产物】（如果有构建流程）
# 说明：自动生成的文件，可以从源码重新构建
# ====================================================================

# 压缩/混淆文件
*.min.js
*.min.css

# Source Maps
*.map

# 构建目录
dist/
build/
out/

# ====================================================================
# 【依赖包】（如果使用 npm/yarn）
# 说明：第三方依赖库，应通过包管理器安装
# ====================================================================

# Node.js
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package-lock.json

# ====================================================================
# 【环境变量和密钥】
# 说明：包含敏感信息的配置文件
# ====================================================================

# 环境变量
.env
.env.local
.env.*.local

# 密钥文件
*.key
*.pem
*.cert

# ====================================================================
# 【测试覆盖率】
# 说明：测试工具生成的覆盖率报告
# ====================================================================

coverage/
.nyc_output/

# ====================================================================
# 【其他】
# 说明：其他需要忽略的文件
# ====================================================================

# Git 自身
.git/

# 项目特定
# 如果有本地配置文件不想提交，可以在这里添加
responsive-logger.js
TEST_REPORT.md
